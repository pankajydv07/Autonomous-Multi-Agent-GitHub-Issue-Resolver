class TestAgentSystemDocumentation:
    """Tests for agent system documentation."""
    
    def test_agent_communication_protocol(self):
        """Verify JSON communication protocol example is valid."""
        readme = Path("README.md").read_text()
        json_match = re.search(r'```json\n(.*?)```', readme, re.DOTALL)
        assert json_match, "Should have JSON communication example"
        
        json_str = json_match.group(1)
        try:
            import json
            data = json.loads(json_str)
            assert "message_type" in data
            assert "from_agent" in data
            assert "to_agent" in data
            assert "payload" in data
            assert "timestamp" in data
        except json.JSONDecodeError as e:
            pytest.fail(f"Invalid JSON in communication protocol example: {e}")
    
    def test_agent_descriptions_complete(self):
        """Verify all agents have descriptions."""
        readme = Path("README.md").read_text()
        agents = ["Planner Agent", "Executor Agent", "Reviewer Agent"]
        for agent in agents:
            assert f"### {agent}" in readme, f"Missing description for {agent}"


