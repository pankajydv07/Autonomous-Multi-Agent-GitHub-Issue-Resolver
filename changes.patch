class TestReadmeStructure:
    """Tests to validate README.md structure and content."""
    
    @pytest.fixture
    def readme_content(self):
        """Load README.md content."""
        readme_path = Path("README.md")
        if not readme_path.exists():
            pytest.skip("README.md not found")
        return readme_path.read_text()
    
    def test_readme_exists(self):
        """Verify README.md file exists."""
        assert Path("README.md").exists(), "README.md should exist"
    
    def test_readme_has_required_sections(self, readme_content):
        """Verify README contains all required sections."""
        required_sections = [
            "# Autonomous Multi-Agent GitHub Issue Resolver",
            "## 📋 Table of Contents",
            "## 🎯 Overview",
            "## 🏗️ Architecture",
            "## ✨ Features",
            "## 📋 Prerequisites",
            "## 🚀 Installation",
            "## ⚙️ Configuration",
            "## 🎮 Usage",
            "## 🤖 Agent System",
            "## 📁 Project Structure",
            "## 🔧 Extensibility",
            "## 🐛 Troubleshooting",
            "## 🤝 Contributing",
            "## 📄 License"
        ]
        for section in required_sections:
            assert section in readme_content, f"Missing section: {section}"
    
    def test_readme_has_badges(self, readme_content):
        """Verify README contains status badges."""
        assert "![Python" in readme_content or "python-" in readme_content
        assert "![License" in readme_content or "License-" in readme_content
    
    def test_readme_code_blocks_valid(self, readme_content):
        """Verify code blocks are properly formatted."""
        # Check for balanced code fences
        code_fence_count = readme_content.count("```")
        assert code_fence_count % 2 == 0, "Code fences should be balanced"
        
        # Check for language specifiers in code blocks
        bash_blocks = re.findall(r'```bash\n(.*?)```', readme_content, re.DOTALL)
        python_blocks = re.findall(r'```python\n(.*?)```', readme_content, re.DOTALL)
        env_blocks = re.findall(r'```env\n(.*?)```', readme_content, re.DOTALL)
        json_blocks = re.findall(r'```json\n(.*?)```', readme_content, re.DOTALL)
        
        assert len(bash_blocks) > 0, "Should have bash code blocks"
        assert len(python_blocks) > 0, "Should have python code blocks"
        assert len(env_blocks) > 0, "Should have env code blocks"
    
    def test_readme_links_valid(self, readme_content):
        """Verify markdown links are properly formatted."""
        link_pattern = r'\[([^\]]+)\]\(([^)]+)\)'
        links = re.findall(link_pattern, readme_content)
        assert len(links) > 0, "Should have markdown links"
        
        # Check for broken anchor links
        anchors = re.findall(r'\(#([^)]+)\)', readme_content)
        headers = re.findall(r'^##+ (.+)$', readme_content, re.MULTILINE)
        header_ids = [h.lower().replace(' ', '-').replace('📋', '').replace('🎯', '').replace('🏗️', '').replace('✨', '').replace('🚀', '').replace('⚙️', '').replace('🎮', '').replace('🤖', '').replace('📁', '').replace('🔧', '').replace('🐛', '').replace('🤝', '').replace('📄', '').strip('-') for h in headers]
        
        for anchor in anchors:
            # Remove emoji and convert to lowercase for comparison
            clean_anchor = re.sub(r'[^\w\s-]', '', anchor).lower()
            assert any(clean_anchor in h for h in header_ids), f"Anchor #{anchor} not found in headers"


class TestConfigurationExamples:
    """Tests for configuration examples in README."""
    
    @pytest.fixture
    def env_example(self):
        """Extract .env example from README."""
        readme = Path("README.md").read_text()
        env_match = re.search(r'```env\n(.*?)```', readme, re.DOTALL)
        if env_match:
            return env_match.group(1)
        return ""
    
    def test_env_has_required_vars(self, env_example):
        """Verify .env example contains required variables."""
        required_vars = [
            "GITHUB_TOKEN",
            "GITHUB_REPO_OWNER",
            "GITHUB_REPO_NAME",
            "OPENAI_API_KEY",
            "PLANNER_MODEL",
            "EXECUTOR_MODEL",
            "REVIEWER_MODEL"
        ]
        for var in required_vars:
            assert var in env_example, f"Missing required env var: {var}"
    
    def test_env_has_optional_vars(self, env_example):
        """Verify .env example contains optional configuration."""
        optional_vars = [
            "TEMPERATURE",
            "MAX_TOKENS",
            "LOG_LEVEL",
            "MAX_CONCURRENT_ISSUES",
            "WORKING_DIRECTORY",
            "ENABLE_AUTO_PR",
            "REQUIRE_HUMAN_APPROVAL",
            "ISSUE_LABELS",
            "EXCLUDE_LABELS"
        ]
        for var in optional_vars:
            assert var in env_example, f"Missing optional env var: {var}"
    
    def test_env_example_parsable(self, env_example, tmp_path):
        """Verify .env example can be parsed."""
        env_file = tmp_path / ".env"
        env_file.write_text(env_example)
        
        # Simulate python-dotenv loading
        env_vars = {}
        for line in env_example.strip().split('\n'):
            if line and not line.startswith('#') and '=' in line:
                key, value = line.split('=', 1)
                env_vars[key] = value
        
        assert "GITHUB_TOKEN" in env_vars
        assert "ghp_" in env_vars.get("GITHUB_TOKEN", "")


